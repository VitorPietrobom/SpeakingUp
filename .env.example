# Firebase (opcional). Sem estas variáveis o site funciona normalmente,
# salvando o progresso do jogo apenas no navegador (localStorage).
#
# Para ativar a sincronização na nuvem:
#   1. Crie um projeto em https://console.firebase.google.com
#   2. Authentication → Sign-in method → ative "Anonymous"
#   3. Crie um banco Cloud Firestore e publique as regras de firestore.rules
#   4. Project settings → "SDK setup and configuration" → copie os valores
#      abaixo para um arquivo .env (não commitado)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Opcional — ativa o Google Analytics do Firebase quando preenchido
VITE_FIREBASE_MEASUREMENT_ID=
