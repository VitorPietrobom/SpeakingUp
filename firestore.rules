rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each (anonymous) user can only touch their own progress document.
    match /progress/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // Aulas content: publicly readable, editable only from the Firebase
    // console / Admin SDK (no client writes).
    match /modulos/{moduloId} {
      allow read: if true;
      allow write: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
